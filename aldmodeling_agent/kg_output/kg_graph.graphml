<edge source="p[A0]" target="N">
  <data key="d1">equation_depends_on</data>
  <data key="d2">unknown</data>
  <data key="d3">N = \int_0^x 2 q W dt = 2 q W \int_0^x \frac{K p_{A0} \left(1 - \frac{x}{x_s}\right)}{1 + K p_{A0} \left(1 - \frac{x}{x_s}\right)} \, dx = 2 q W \left( x + \frac{x_s}{K p_{A0}} \ln \frac{K p_{A0} \left(1 - \frac{x}{x_s}\right)}{K p_{A0} + 1} \right)</data>
  <data key="d4">equation</data>
  <data key="d5"></data>
</edge>
<edge source="p[A0]" target="x[s]">
  <data key="d1">co_appears_in_equation</data>
  <data key="d2">undirected</data>
  <data key="d3">N = \int_0^x 2 q W dt = 2 q W \int_0^x \frac{K p_{A0} \left(1 - \frac{x}{x_s}\right)}{1 + K p_{A0} \left(1 - \frac{x}{x_s}\right)} \, dx = 2 q W \left( x + \frac{x_s}{K p_{A0}} \ln \frac{K p_{A0} \left(1 - \frac{x}{x_s}\right)}{K p_{A0} + 1} \right)</data>
  <data key="d4">equation</data>
  <data key="d5"></data>
</edge>
<edge source="p[A0]" target="D">
  <data key="d1">equation_depends_on</data>
  <data key="d2">unknown</data>
  <data key="d3">D = \frac{\rho_A D H_{\text{eff}}}{-q k_B T \left( 1 - \ln (K p_{A0} + 1) \right) K p_{A0}}</data>
  <data key="d4">equation</data>
  <data key="d5"></data>
</edge>
<edge source="p[A0]" target="F">
  <data key="d1">equation_depends_on</data>
  <data key="d2">unknown</data>
  <data key="d3">F = \frac{p_A0 N_0}{\sqrt{2 \pi M_A R T}} \frac{W H}{1 + \frac{3 \chi}{8} \left( \frac{1}{H} + \frac{1}{W} \right)},</data>
  <data key="d4">equation</data>
  <data key="d5"></data>
</edge>
